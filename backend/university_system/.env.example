SECRET_KEY=change-this-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Local development can keep SQLite by leaving DB_ENGINE as sqlite.
DB_ENGINE=sqlite

# PostgreSQL option 1: single URL, useful for Render/Railway/Neon/Supabase.
# DATABASE_URL=postgresql://postgres:password@localhost:5432/complaint_system

# PostgreSQL option 2: individual variables.
# DB_ENGINE=postgresql
# DB_NAME=complaint_system
# DB_USER=postgres
# DB_PASSWORD=change-this-password
# DB_HOST=localhost
# DB_PORT=5432

EMAIL_NOTIFICATIONS_ENABLED=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
BOT_API_KEY=change-this-bot-key
